ENVIRONMENT=DEVELOPMENT
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
DB_DRIVER=postgres
DB_SOURCE=postgres://postgres:password@localhost:5432/headlamp?sslmode=disable
MIGRATION_URL=file://db/migration
REDIS_ADDRESS=localhost:6379
HTTP_SERVER_ADDRESS=0.0.0.0:8080
SERVER_ADDRESS=0.0.0.0:8080
TOKEN_SYMMETRIC_KEY=your-32-character-secret-key-here
ACCESS_TOKEN_DURATION=15m
REFRESH_TOKEN_DURATION=24h
EMAIL_SENDER_NAME=HeadLamp
EMAIL_SENDER_ADDRESS=noreply@headlamp.com
EMAIL_SENDER_PASSWORD=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_CLIENT_ID=
OAUTH_REDIRECT_BASE_URL=http://localhost:8080
PARENT_PASSWORD_AUTH_DISABLED=false
EXTERNAL_CONTENT_BASE_URL=http://your-content-server.com
EXTERNAL_CONTENT_TOKEN=your-content-token-here
EXTERNAL_REQUEST_TIMEOUT=30s
OPENAI_API_KEY=sk-your-openai-api-key-here
REFLECTION_CRON_SCHEDULE=0 8 * * *
REFLECTION_TEST_MODE=false

# Firebase Admin SDK (for Google + Apple social login via Flutter Firebase Auth)
# Get from: Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_PROJECT_ID=your-firebase-project-id
# Paste the entire service account JSON as a single line (escape any newlines in the private_key field)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}
